# Supabase 연결 정보 — 이 파일을 .env.local 로 복사한 뒤 실제 값으로 채우세요.
#   cp .env.local.example .env.local
#
# 값은 Supabase 프로젝트의 Settings → API 에서 확인할 수 있습니다.
# (my-work 와 데이터가 섞이지 않도록 반드시 새 Supabase 프로젝트를 사용하세요.)

# ── 클라이언트/서버 공통 (브라우저에 노출됨) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── 서버 전용 (절대 브라우저 노출 금지 / NEXT_PUBLIC 접두사 없음) ──
# 팀원 계정 발급(관리자 기능)에 필요. Supabase Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# 관리자(계정 발급 권한) 이메일 목록. 콤마로 여러 명 지정 가능.
ADMIN_EMAILS=admin@example.com

# ── Cloudflare R2 (정적 보고서 배포용, 선택) ──
# `npm run report:imk:deploy` 로 report/관제판-imk.html 을 R2에 업로드할 때만 필요.
# Cloudflare 대시보드 → R2 → Manage R2 API Tokens 에서 S3 자격증명(Access Key) 발급.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# 업로드 객체 키(파일명). 사용자가 새로고침만 해도 갱신되도록 항상 같은 키로 덮어씀.
R2_OBJECT_KEY=관제판-imk.html
# 연동 일정 문서(report:schedule:deploy)의 객체 키. 생략 시 기본값 사용.
R2_OBJECT_KEY_SCHEDULE=연동일정-충전기술지원팀.html
# 캐시 정책: no-cache = 매 요청 재검증(덮어쓰면 새로고침 즉시 반영). 기본값.
R2_CACHE_CONTROL=no-cache
# (선택) 공개 URL 베이스. 설정 시 업로드 후 최종 URL을 출력해 줌.
R2_PUBLIC_BASE=https://your-custom-domain.example.com
