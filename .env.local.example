# Supabase 연결 정보 — 이 파일을 .env.local 로 복사한 뒤 실제 값으로 채우세요.
#   cp .env.local.example .env.local
#
# 값은 Supabase 프로젝트의 Settings → API 에서 확인할 수 있습니다.
# (my-work 와 데이터가 섞이지 않도록 반드시 새 Supabase 프로젝트를 사용하세요.)

# ── 클라이언트/서버 공통 (브라우저에 노출됨) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── 서버 전용 (절대 브라우저 노출 금지 / NEXT_PUBLIC 접두사 없음) ──
# 팀원 계정 발급(관리자 기능)에 필요. Supabase Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# 관리자(계정 발급 권한) 이메일 목록. 콤마로 여러 명 지정 가능.
ADMIN_EMAILS=admin@example.com
